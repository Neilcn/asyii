{% doc %}
  @prompt
    Create a video carousel section that displays multiple videos in a sliding carousel format. The carousel should allow customers to browse through videos with navigation arrows and be customizable for different video sources. ratio 9:16, caroual, but I want to add or delete video
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
  }

  .ai-video-carousel__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
  }

  .ai-video-carousel__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
    gap: {{ block.settings.gap }}px;
  }

  .ai-video-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: calc((100% - ({{ block.settings.slides_per_view | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.slides_per_view }});
  }

  .ai-video-carousel__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    background-color: #000000;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-video-carousel__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    color: #666666;
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  .ai-video-carousel__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666666;
    font-size: 16px;
  }

  .ai-video-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: all 0.3s ease;
    opacity: {{ block.settings.arrow_opacity | divided_by: 100.0 }};
  }

  .ai-video-carousel__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    color: {{ block.settings.arrow_hover_color }};
    opacity: 1;
  }

  .ai-video-carousel__nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-video-carousel__nav--prev-{{ ai_gen_id }} {
    left: {{ block.settings.arrow_offset }}px;
  }

  .ai-video-carousel__nav--next-{{ ai_gen_id }} {
    right: {{ block.settings.arrow_offset }}px;
  }

  .ai-video-carousel__nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.arrow_size }}px * 0.5);
    height: calc({{ block.settings.arrow_size }}px * 0.5);
  }

  .ai-video-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: {{ block.settings.dots_spacing }}px;
  }

  .ai-video-carousel__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.5;
  }

  .ai-video-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 1;
  }

  .ai-video-carousel__video-controls-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
    margin-top: 10px;
    justify-content: center;
  }

  .ai-video-carousel__control-btn-{{ ai_gen_id }} {
    padding: 8px 16px;
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: 1px solid {{ block.settings.arrow_color }};
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
    transition: all 0.3s ease;
  }

  .ai-video-carousel__control-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    color: {{ block.settings.arrow_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-video-carousel__slide-{{ ai_gen_id }} {
      width: calc((100% - ({{ block.settings.slides_per_view_mobile | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.slides_per_view_mobile }});
    }

    .ai-video-carousel__nav-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_size | times: 0.8 }}px;
      height: {{ block.settings.arrow_size | times: 0.8 }}px;
    }

    .ai-video-carousel__nav--prev-{{ ai_gen_id }} {
      left: {{ block.settings.arrow_offset | times: 0.5 }}px;
    }

    .ai-video-carousel__nav--next-{{ ai_gen_id }} {
      right: {{ block.settings.arrow_offset | times: 0.5 }}px;
    }
  }
{% endstyle %}

<video-carousel-{{ ai_gen_id }} class="ai-video-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% assign video_count = 0 %}
  {% for i in (1..10) %}
    {% assign video_key = 'video_' | append: i %}
    {% if block.settings[video_key] != blank %}
      {% assign video_count = video_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% if video_count > 0 %}
    <div class="ai-video-carousel__container-{{ ai_gen_id }}">
      <div class="ai-video-carousel__track-{{ ai_gen_id }}">
        {% for i in (1..10) %}
          {% assign video_key = 'video_' | append: i %}
          {% assign video = block.settings[video_key] %}
          
          {% if video != blank %}
            <div class="ai-video-carousel__slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
              <div class="ai-video-carousel__video-wrapper-{{ ai_gen_id }}">
                {% if video.sources[1].url %}
                  <video
                    class="ai-video-carousel__video-{{ ai_gen_id }}"
                    {% if block.settings.autoplay %}autoplay{% endif %}
                    {% if block.settings.loop %}loop{% endif %}
                    {% if block.settings.muted %}muted{% endif %}
                    playsinline
                    {% if block.settings.controls %}controls{% endif %}
                  >
                    <source src="{{ video.sources[1].url }}" type="{{ video.sources[1].mime_type }}">
                  </video>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.show_arrows %}
        <button
          class="ai-video-carousel__nav-{{ ai_gen_id }} ai-video-carousel__nav--prev-{{ ai_gen_id }}"
          aria-label="Previous slide"
          data-nav="prev"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button
          class="ai-video-carousel__nav-{{ ai_gen_id }} ai-video-carousel__nav--next-{{ ai_gen_id }}"
          aria-label="Next slide"
          data-nav="next"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% endif %}
    </div>

    {% if block.settings.show_dots %}
      <div class="ai-video-carousel__dots-{{ ai_gen_id }}"></div>
    {% endif %}
  {% else %}
    <div class="ai-video-carousel__empty-state-{{ ai_gen_id }}">
      Add videos using the settings below to start building your carousel
    </div>
  {% endif %}
</video-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slidesPerView = {{ block.settings.slides_per_view }};
        this.slidesPerViewMobile = {{ block.settings.slides_per_view_mobile }};
        this.gap = {{ block.settings.gap }};
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-video-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-video-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-nav="prev"]');
        this.nextButton = this.querySelector('[data-nav="next"]');
        this.dotsContainer = this.querySelector('.ai-video-carousel__dots-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.updateSlidesPerView();
        this.setupEventListeners();
        this.createDots();
        this.updateCarousel();

        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.updateCarousel();
        });
      }

      updateSlidesPerView() {
        this.currentSlidesPerView = window.innerWidth <= 749 
          ? this.slidesPerViewMobile 
          : this.slidesPerView;
        this.maxIndex = Math.max(0, this.slides.length - this.currentSlidesPerView);
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.navigate(-1));
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.navigate(1));
        }
      }

      navigate(direction) {
        this.currentIndex = Math.max(0, Math.min(this.maxIndex, this.currentIndex + direction));
        this.updateCarousel();
      }

      updateCarousel() {
        if (this.slides.length === 0) return;
        
        const slideWidth = this.slides[0].offsetWidth;
        const offset = -(this.currentIndex * (slideWidth + this.gap));
        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= this.maxIndex;
        }

        this.updateDots();
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.dotsContainer.innerHTML = '';
        const totalDots = Math.max(1, this.slides.length - this.currentSlidesPerView + 1);

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-video-carousel__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.updateCarousel();
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      updateDots() {
        if (!this.dotsContainer) return;

        const dots = this.dotsContainer.querySelectorAll('.ai-video-carousel__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('video-carousel-{{ ai_gen_id }}', VideoCarousel{{ ai_gen_id }});
  })();
</script>

