{% doc %}
  @prompt
    i want a video carousal, but for 3 videos, so for desktop, they dont swipe, but for mobile or tablet, they can be swiped, videos are in a ratio 16:9, i can adjust how many vdeos show on 1 page , sorry it was the ratio 6:19, the  ratio just fit with the media i upload, can i add title to this section and also add a link to the videos so people can visit
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-carousel-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-video-carousel__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.title_spacing }}px;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-video-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  .ai-video-carousel__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-video-carousel__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.videos_per_row_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-video-carousel__item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: {{ block.settings.video_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-video-carousel__link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .ai-video-carousel__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-video-carousel__video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-video-carousel__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0);
    transition: background-color 0.3s ease;
    pointer-events: none;
  }

  .ai-video-carousel__link-{{ ai_gen_id }}:hover .ai-video-carousel__overlay-{{ ai_gen_id }} {
    background-color: rgba(0, 0, 0, 0.1);
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 9 / 16;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-video-carousel__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-carousel__controls-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 989px) {
    .ai-video-carousel__grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-video-carousel__grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-video-carousel__item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.video_width_tablet }}%;
      scroll-snap-align: center;
    }

    .ai-video-carousel__controls-{{ ai_gen_id }} {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin-top: 16px;
    }

    .ai-video-carousel__dot-{{ ai_gen_id }} {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background-color: {{ block.settings.dot_color }};
      opacity: 0.3;
      transition: opacity 0.3s ease;
      border: none;
      padding: 0;
      cursor: pointer;
    }

    .ai-video-carousel__dot-{{ ai_gen_id }}.active {
      opacity: 1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-video-carousel__item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.video_width_mobile }}%;
    }

    .ai-video-carousel__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }
{% endstyle %}

<video-carousel-{{ ai_gen_id }}
  class="ai-video-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank %}
    <div class="ai-video-carousel__header-{{ ai_gen_id }}">
      <h2 class="ai-video-carousel__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    </div>
  {% endif %}

  <div class="ai-video-carousel__container-{{ ai_gen_id }}">
    <div class="ai-video-carousel__grid-{{ ai_gen_id }}" data-carousel>
      {% for i in (1..block.settings.total_videos) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign link_key = 'video_link_' | append: i
          assign video = block.settings[video_key]
          assign link = block.settings[link_key]
        %}
        <div class="ai-video-carousel__item-{{ ai_gen_id }}" data-video-item>
          {% if video %}
            {% if link != blank %}
              <a href="{{ link }}" class="ai-video-carousel__link-{{ ai_gen_id }}">
                <div class="ai-video-carousel__video-wrapper-{{ ai_gen_id }}">
                  <video
                    class="ai-video-carousel__video-{{ ai_gen_id }}"
                    {% if block.settings.autoplay %}autoplay{% endif %}
                    {% if block.settings.loop %}loop{% endif %}
                    {% if block.settings.muted %}muted{% endif %}
                    {% if block.settings.controls %}controls{% endif %}
                    playsinline
                  >
                    <source src="{{ video.sources[1].url }}" type="{{ video.sources[1].mime_type }}">
                  </video>
                  <div class="ai-video-carousel__overlay-{{ ai_gen_id }}"></div>
                </div>
              </a>
            {% else %}
              <div class="ai-video-carousel__video-wrapper-{{ ai_gen_id }}">
                <video
                  class="ai-video-carousel__video-{{ ai_gen_id }}"
                  {% if block.settings.autoplay %}autoplay{% endif %}
                  {% if block.settings.loop %}loop{% endif %}
                  {% if block.settings.muted %}muted{% endif %}
                  {% if block.settings.controls %}controls{% endif %}
                  playsinline
                >
                  <source src="{{ video.sources[1].url }}" type="{{ video.sources[1].mime_type }}">
                </video>
              </div>
            {% endif %}
          {% else %}
            <div class="ai-video-carousel__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-video-carousel__empty-state-{{ ai_gen_id }}">
                Add video {{ i }}
              </div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="ai-video-carousel__controls-{{ ai_gen_id }}" data-controls>
      {% for i in (1..block.settings.total_videos) %}
        {% assign index = i | minus: 1 %}
        <button 
          class="ai-video-carousel__dot-{{ ai_gen_id }}{% if i == 1 %} active{% endif %}" 
          data-dot="{{ index }}" 
          aria-label="Go to video {{ i }}"
        ></button>
      {% endfor %}
    </div>
  </div>
</video-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.carousel = this.querySelector('[data-carousel]');
        this.dots = this.querySelectorAll('[data-dot]');
        this.items = this.querySelectorAll('[data-video-item]');

        if (window.innerWidth <= 989) {
          this.setupCarousel();
        }

        window.addEventListener('resize', () => {
          if (window.innerWidth <= 989) {
            this.setupCarousel();
          } else {
            this.removeCarousel();
          }
        });
      }

      setupCarousel() {
        if (this.scrollListener) return;

        this.scrollListener = () => {
          this.updateActiveDot();
        };

        this.carousel.addEventListener('scroll', this.scrollListener);

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.dot);
            this.scrollToItem(index);
          });
        });

        this.updateActiveDot();
      }

      removeCarousel() {
        if (this.scrollListener) {
          this.carousel.removeEventListener('scroll', this.scrollListener);
          this.scrollListener = null;
        }
      }

      scrollToItem(index) {
        const item = this.items[index];
        if (item) {
          item.scrollIntoView({
            behavior: 'smooth',
            block: 'nearest',
            inline: 'center'
          });
        }
      }

      updateActiveDot() {
        const scrollLeft = this.carousel.scrollLeft;
        const itemWidth = this.items[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.carousel).gap) || 0;
        const currentIndex = Math.round(scrollLeft / (itemWidth + gap));

        this.dots.forEach((dot, index) => {
          if (index === currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('video-carousel-{{ ai_gen_id }}', VideoCarousel{{ ai_gen_id }});
  })();
</script>

