{% doc %}
  @prompt
    Create a full-page width product recommendation quiz block with a customizable title, 3 multiple-choice questions with emoji-styled answer buttons, and product recommendation results. 
    
    The quiz should include:
    - Editable quiz title in block settings (default: "Not sure where to start?")
    - Question 1: "Who are you shopping for?" with 5 answer options (Myself, A best friend, A bride-to-be, A wedding guest moment, Mum/Mother figure)
    - Question 2: "What's the occasion?" with 4 answer options (Birthday/Celebration, Wedding/Bridal shower, Holiday/Christmas, Just because)
    - Question 3: "What vibe are you going for?" with 4 answer options (Soft & romantic, Minimal & elegant, Artistic & bold, Timeless & classic)
    - Results page showing 2 recommended products with optional custom recommendation messages
    
    Backend settings should allow the store owner to:
    - Manually assign 2 specific products for each answer combination
    - Add custom recommendation text for each product result
    - Customize the quiz title
    - Style the quiz (colors, fonts, button styles)
    
    The design should be full-page width, mobile-responsive, with smooth transitions between questions, clear answer buttons with emojis, and an attractive results display showing the 2 matched products with images, titles, prices, and optional recommendation messages.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-quiz-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-quiz-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-quiz-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-align: center;
    margin: 0 0 40px;
  }

  .ai-quiz-question-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-quiz-question-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-quiz-question-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_size }}px;
    color: {{ block.settings.question_color }};
    text-align: center;
    margin: 0 0 30px;
  }

  .ai-quiz-answers-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 30px;
  }

  .ai-quiz-answer-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: 20px;
    font-size: {{ block.settings.button_text_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .ai-quiz-answer-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-quiz-emoji-{{ ai_gen_id }} {
    font-size: {{ block.settings.emoji_size }}px;
    line-height: 1;
  }

  .ai-quiz-progress-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.progress_color }};
    font-size: 14px;
    margin-bottom: 20px;
  }

  .ai-quiz-progress-bar-{{ ai_gen_id }} {
    width: 100%;
    height: 6px;
    background-color: {{ block.settings.progress_bg_color }};
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 30px;
  }

  .ai-quiz-progress-fill-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.progress_fill_color }};
    transition: width 0.3s ease;
    width: 0%;
  }

  .ai-quiz-results-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-quiz-results-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-quiz-results-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.results_title_size }}px;
    color: {{ block.settings.results_title_color }};
    text-align: center;
    margin: 0 0 40px;
  }

  .ai-quiz-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    margin-bottom: 30px;
  }

  .ai-quiz-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.product_card_bg }};
    border: 1px solid {{ block.settings.product_card_border }};
    border-radius: {{ block.settings.product_card_radius }}px;
    padding: 20px;
    text-align: center;
  }

  .ai-quiz-product-image-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 16px;
    border-radius: {{ block.settings.product_image_radius }}px;
    overflow: hidden;
  }

  .ai-quiz-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-quiz-product-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.product_image_radius }}px;
  }

  .ai-quiz-product-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-quiz-product-title-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-quiz-product-price-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.product_price_color }};
    margin-bottom: 12px;
  }

  .ai-quiz-product-message-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.product_message_color }};
    margin-bottom: 16px;
    font-style: italic;
  }

  .ai-quiz-product-link-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    padding: 12px 24px;
    border-radius: {{ block.settings.cta_border_radius }}px;
    text-decoration: none;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .ai-quiz-product-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    color: {{ block.settings.cta_hover_text_color }};
  }

  .ai-quiz-restart-btn-{{ ai_gen_id }} {
    display: block;
    margin: 30px auto 0;
    background-color: {{ block.settings.restart_bg_color }};
    color: {{ block.settings.restart_text_color }};
    border: 1px solid {{ block.settings.restart_border_color }};
    padding: 12px 30px;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 16px;
    transition: all 0.3s ease;
  }

  .ai-quiz-restart-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.restart_hover_bg_color }};
    color: {{ block.settings.restart_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-quiz-answers-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-quiz-products-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-quiz-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-quiz-question-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

