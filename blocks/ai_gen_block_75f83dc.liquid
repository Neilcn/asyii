<script>
  (function() {
    class ProductQuiz{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentQuestion = 1;
        this.answers = {};
        this.productMappings = this.buildProductMappings();
      }

      connectedCallback() {
        this.questions = this.querySelectorAll('.ai-quiz-question-{{ ai_gen_id }}');
        this.resultsSection = this.querySelector('.ai-quiz-results-{{ ai_gen_id }}');
        this.progressFill = this.querySelector('.ai-quiz-progress-fill-{{ ai_gen_id }}');
        this.progressText = this.querySelector('.current-question');
        this.answerButtons = this.querySelectorAll('.ai-quiz-answer-btn-{{ ai_gen_id }}');
        this.restartButton = this.querySelector('.ai-quiz-restart-btn-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.updateProgress();
      }

      buildProductMappings() {
        const mappings = {};
        {% for i in (1..80) %}
          {% assign combo_key = 'combo_' | append: i %}
          {% assign product1_key = 'combo_' | append: i | append: '_product1' %}
          {% assign product2_key = 'combo_' | append: i | append: '_product2' %}
          {% assign message1_key = 'combo_' | append: i | append: '_message1' %}
          {% assign message2_key = 'combo_' | append: i | append: '_message2' %}
          
          {% assign combo = block.settings[combo_key] %}
          {% assign product1 = block.settings[product1_key] %}
          {% assign product2 = block.settings[product2_key] %}
          {% assign message1 = block.settings[message1_key] %}
          {% assign message2 = block.settings[message2_key] %}
          
          {% if combo != blank and product1 != blank %}
            mappings['{{ combo }}'] = {
              product1: {
                {% if product1.featured_image %}
                  image: '{{ product1.featured_image | image_url: width: 600 }}',
                {% endif %}
                title: '{{ product1.title | escape }}',
                price: '{{ product1.price | money }}',
                url: '{{ product1.url }}',
                message: '{{ message1 | escape }}'
              },
              product2: {
                {% if product2.featured_image %}
                  image: '{{ product2.featured_image | image_url: width: 600 }}',
                {% endif %}
                title: '{{ product2.title | escape }}',
                price: '{{ product2.price | money }}',
                url: '{{ product2.url }}',
                message: '{{ message2 | escape }}'
              }
            };
          {% endif %}
        {% endfor %}
        return mappings;
      }

      setupEventListeners() {
        this.answerButtons.forEach(button => {
          button.addEventListener('click', (e) => this.handleAnswer(e));
        });

        this.restartButton.addEventListener('click', () => this.restartQuiz());
      }

      handleAnswer(e) {
        const answer = e.currentTarget.dataset.answer;
        this.answers['q' + this.currentQuestion] = answer;

        if (this.currentQuestion < 3) {
          this.currentQuestion++;
          this.showQuestion(this.currentQuestion);
          this.updateProgress();
        } else {
          this.showResults();
        }
      }

      showQuestion(questionNumber) {
        this.questions.forEach(q => {
          q.classList.remove('active');
        });

        const nextQuestion = this.querySelector(`[data-question="${questionNumber}"]`);
        if (nextQuestion) {
          setTimeout(() => {
            nextQuestion.classList.add('active');
          }, 100);
        }
      }

      updateProgress() {
        const progress = ((this.currentQuestion - 1) / 3) * 100;
        this.progressFill.style.width = progress + '%';
        this.progressText.textContent = this.currentQuestion;
      }

      showResults() {
        const comboKey = this.answers.q1 + '_' + this.answers.q2 + '_' + this.answers.q3;
        const products = this.productMappings[comboKey];

        this.questions.forEach(q => q.classList.remove('active'));

        if (products) {
          this.displayProducts(products);
        } else {
          this.displayDefaultProducts();
        }

        setTimeout(() => {
          this.resultsSection.classList.add('active');
          this.resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }

      displayProducts(products) {
        const productCards = this.querySelectorAll('.ai-quiz-product-card-{{ ai_gen_id }}');

        [products.product1, products.product2].forEach((product, index) => {
          const card = productCards[index];
          if (!card || !product.title) return;

          const imageContainer = card.querySelector('.ai-quiz-product-image-{{ ai_gen_id }}');
          const title = card.querySelector('.ai-quiz-product-title-{{ ai_gen_id }}');
          const price = card.querySelector('.ai-quiz-product-price-{{ ai_gen_id }}');
          const message = card.querySelector('.ai-quiz-product-message-{{ ai_gen_id }}');
          const link = card.querySelector('.ai-quiz-product-link-{{ ai_gen_id }}');

          if (product.image) {
            imageContainer.innerHTML = '<img src="' + product.image + '" alt="' + product.title + '" loading="lazy">';
          }

          title.textContent = product.title;
          price.textContent = product.price;
          
          if (product.message) {
            message.textContent = product.message;
            message.style.display = 'block';
          } else {
            message.style.display = 'none';
          }

          link.href = product.url;
        });
      }

      displayDefaultProducts() {
        const productCards = this.querySelectorAll('.ai-quiz-product-card-{{ ai_gen_id }}');
        productCards.forEach(card => {
          const title = card.querySelector('.ai-quiz-product-title-{{ ai_gen_id }}');
          const message = card.querySelector('.ai-quiz-product-message-{{ ai_gen_id }}');
          
          title.textContent = 'No product assigned';
          message.textContent = 'Please configure products for this answer combination in the block settings.';
          message.style.display = 'block';
        });
      }

      restartQuiz() {
        this.currentQuestion = 1;
        this.answers = {};
        this.resultsSection.classList.remove('active');
        this.showQuestion(1);
        this.updateProgress();
        this.querySelector('.ai-quiz-container-{{ ai_gen_id }}').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    customElements.define('product-quiz-{{ ai_gen_id }}', ProductQuiz{{ ai_gen_id }});
  })();
</script>

{% schema %}
