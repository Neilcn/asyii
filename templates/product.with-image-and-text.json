              },
              "blocks": {
                "text_Ethmcj": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We recommend dry cleaning or gentle hand-washing in cold water with a silk-specific detergent. Air dry away from direct sunlight. Our double-faced prints are designed to retain their vibrancy with proper care.<br/></p>",
